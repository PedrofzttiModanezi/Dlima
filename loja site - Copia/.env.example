# SQLite — arquivo criado em prisma/dev.db após `npm run db:push`
DATABASE_URL="file:./dev.db"

# Stripe — https://dashboard.stripe.com/apikeys
# Use chaves de teste (pk_test_... / sk_test_...) durante o desenvolvimento
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# URL pública do site (checkout Stripe). Em dev: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

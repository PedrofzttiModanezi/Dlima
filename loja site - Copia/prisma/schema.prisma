generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  model       String
  description String
  priceCents  Int
  imageUrl    String?
  createdAt   DateTime @default(now())
}
